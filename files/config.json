{
    "height": 20,
    "position": "top",
    "font": "monospace, Font Awesome 6 Free 11",
    "background": "#2e3440",
    "foreground": "#e5e9f0",

    "mods_left": {
        "padding": {"size":32},
        "workspace": {},
    },
    "mods_right": {
        "padding": {"size":32},
        "datetime": {"format": "%Y-%m-%d %H:%M"},
        "pipewire": {"format": " {}", "format_muted": ""},
        "battery": {"name": "BAT0", "format": " {}", "style": "graph"},
        "temp": {"path": "/sys/class/hwmon/hwmon0/temp0_input", "format": " {}"},
        "network": {"wired": " {}", "wireless": " {}", "offline": "⚠"},
        "loadavg": {"format": "LA {}"},
        "ram_usage": {"format": " {}"},
        "cpu_usage": {"format": " {}"},
    }
}
