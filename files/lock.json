{
    "font": "monospace, Font Awesome 6 Free 11",
    "background": "#2e3440",
    "foreground": "#e5e9f0",

    // optional: default to $XDG_DATA_HOME/swaybarpp/passwd
    "passwd_file": "/home/mojyack/.local/share/swaybarpp/passwd",

    // optional: execute "suspend_command" on "timeout" inactivity
    "timeout": 10,
    "suspend_command": ["doas", "/usr/local/bin/suspend"],

    // optional: scale every geometry (numpad, dots, font size); default 1.0
    "scale": 1.0,
}
